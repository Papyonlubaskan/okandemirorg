// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  role          String    @default("customer")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  addresses     Address[]
  reviews       Review[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  parent      Category? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToCategory")
  products    ProductCategory[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  description     String?
  shortDescription String?
  price           Float
  salePrice       Float?
  sku             String?   @unique
  stock           Int       @default(0)
  featured        Boolean   @default(false)
  status          String    @default("published")
  images          ProductImage[]
  categories      ProductCategory[]
  orderItems      OrderItem[]
  reviews         Review[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  order     Int      @default(0)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductCategory {
  id         String   @id @default(cuid())
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  status          String      @default("pending")
  total           Float
  subtotal        Float
  tax             Float       @default(0)
  shipping        Float       @default(0)
  paymentMethod   String?
  paymentStatus   String      @default("pending")
  shippingAddress Address?    @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address?    @relation("BillingAddress", fields: [billingAddressId], references: [id])
  shippingAddressId String?
  billingAddressId  String?
  items           OrderItem[]
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  total     Float
}

model Address {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  company       String?
  address1      String
  address2      String?
  city          String
  state         String
  postalCode    String
  country       String
  phone         String?
  isDefault     Boolean @default(false)
  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  title     String?
  comment   String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// AI-Powered Customer Analysis Models
model ContactSubmission {
  id                String   @id @default(cuid())
  name              String
  email             String
  phone             String?
  company           String?
  message           String
  source            String   @default("contact_form") // contact_form, landing_page, chatbot
  
  // AI Analysis Fields
  aiCategory        String?  // web_design, digital_marketing, seo, development, branding
  aiSentiment       String?  // positive, neutral, negative
  aiPriority        String?  // high, medium, low
  aiEstimatedBudget String?  // low, medium, high, enterprise
  aiKeywords        String?  // JSON array of extracted keywords
  aiSummary         String?  // AI-generated summary
  aiConfidence      Float?   // 0-1 confidence score
  
  // Status tracking
  status            String   @default("new") // new, contacted, qualified, converted, archived
  assignedTo        String?  // Admin user who handles this
  notes             String?  // Admin notes
  followUpDate      DateTime?
  
  // Metadata
  ipAddress         String?
  userAgent         String?
  referrer          String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  interactions      CustomerInteraction[]
  
  @@index([status])
  @@index([aiCategory])
  @@index([aiPriority])
  @@index([createdAt])
}

model CustomerInteraction {
  id                    String   @id @default(cuid())
  contactSubmissionId   String
  contactSubmission     ContactSubmission @relation(fields: [contactSubmissionId], references: [id], onDelete: Cascade)
  
  type                  String   // email, call, meeting, note
  content               String
  outcome               String?  // successful, pending, failed
  nextAction            String?
  nextActionDate        DateTime?
  
  createdBy             String?  // Admin user
  createdAt             DateTime @default(now())
  
  @@index([contactSubmissionId])
  @@index([createdAt])
}

model AIAnalyticsLog {
  id                String   @id @default(cuid())
  eventType         String   // page_view, form_submit, click, scroll, time_on_page
  page              String
  
  // User data
  sessionId         String
  userId            String?
  ipAddress         String?
  userAgent         String?
  
  // Event data
  eventData         String?  // JSON data
  
  // AI Insights
  aiInsights        String?  // JSON with AI-generated insights
  
  createdAt         DateTime @default(now())
  
  @@index([sessionId])
  @@index([eventType])
  @@index([page])
  @@index([createdAt])
}

// Customer Satisfaction Survey Models
model Survey {
  id                String   @id @default(cuid())
  projectId         String?  // Optional project reference
  customerName      String
  customerEmail     String
  
  // Ratings (1-5)
  overallRating     Int
  communicationRating Int
  qualityRating     Int
  timelinessRating  Int
  valueRating       Int
  
  // Feedback
  whatWorkedWell    String?
  whatCouldImprove  String?
  wouldRecommend    Boolean
  testimonial       String?  // Can be used on website
  allowPublic       Boolean  @default(false)
  
  // Metadata
  completedAt       DateTime @default(now())
  ipAddress         String?
  
  @@index([customerEmail])
  @@index([overallRating])
  @@index([completedAt])
}

model SurveyInvitation {
  id                String   @id @default(cuid())
  customerEmail     String
  customerName      String
  projectId         String?
  token             String   @unique
  
  sentAt            DateTime @default(now())
  completedAt       DateTime?
  reminderSentAt    DateTime?
  
  @@index([customerEmail])
  @@index([token])
}
