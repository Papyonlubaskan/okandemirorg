# Railway Environment Variables
NEXT_PUBLIC_SITE_URL=https://okandemir.org
NEXT_PUBLIC_SITE_NAME=Okan Demir - Dijital Pazarlama Uzmanı
NEXT_PUBLIC_SITE_DESCRIPTION=Dijital Pazarlama Uzmanı, Web Tasarım, SEO, Google Ads, Meta Business, Sosyal Medya Yönetimi

# Email Configuration (Railway'de ayarlanacak)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# YouTube API (Railway'de ayarlanacak)
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CHANNEL_ID=your-channel-id

# Instagram API (Railway'de ayarlanacak)
INSTAGRAM_ACCESS_TOKEN=your-instagram-token

# Database (Railway'de otomatik oluşturulacak)
DATABASE_URL=postgresql://username:password@host:port/database

# Next.js
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=production
