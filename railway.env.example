# Railway ortam degiskenleri sablonu
# Bu dosyayi railway.env olarak kopyalayin ve degerleri doldurun
# railway.env asla Git'e eklenmemelidir

NEXT_PUBLIC_SITE_URL=https://okandemir.org
NEXT_PUBLIC_SITE_NAME=Dijital Pazarlama Uzmani | Okan Demir
NEXT_PUBLIC_GA_ID=your-ga-id

EMAIL_HOST=okandemir.org
EMAIL_PORT=465
EMAIL_USER=info@okandemir.org
EMAIL_PASS=your-email-password
EMAIL_FROM=info@okandemir.org

YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CHANNEL_ID=your-channel-id

INSTAGRAM_APP_ID=your-app-id
INSTAGRAM_APP_SECRET=your-app-secret
INSTAGRAM_ACCESS_TOKEN=your-access-token

MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=railway

NEXT_TELEMETRY_DISABLED=1
NODE_ENV=production
